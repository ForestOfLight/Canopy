            }
        },
        {
            "label": "regolith: run release",
            "type": "shell",
            "command": "regolith run release",
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "close": false
            }
        },
        {
            "label": "regolith: bump version",
            "type": "shell",
            "command": "regolith run bump-version",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "new",
                "close": false
            }
        },
        {
            "label": "regolith: watch default",
            "type": "shell",
            "command": "regolith watch default",
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "."
                }
            },
            "presentation": {
                "echo": true,
                "close": true
            }
        },
        {
            "label": "regolith: watch preview",
